{
  "name": "@tensorworks/buccaneer-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end integration tests for Buccaneer metrics pipeline",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "pretest": "npm run docker:up",
    "posttest": "npm run docker:down",
    "docker:up": "docker compose -f ../Examples/Compose/docker-compose.yml up -d --wait",
    "docker:down": "docker compose -f ../Examples/Compose/docker-compose.yml down -v",
    "docker:logs": "docker compose -f ../Examples/Compose/docker-compose.yml logs"
  },
  "devDependencies": {
    "@tensorworks/buccaneer-metrics-client": "file:../Web/metrics-client",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "undici-types": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TensorWorks/Buccaneer.git"
  },
  "author": "TensorWorks Pty Ltd",
  "license": "MIT"
}
